---
const { categories } = Astro.props;

---
<span>
{Array.isArray(categories) ? 
    
      categories.map((category: string) => 
        <a href="lala" class="category">{category}</a>
      )
    
   : 
 
      <a href="lala"  class="category">{categories}</a>
    
  }

</span>

<style>
    a.category:link {
    text-decoration: none;
    color: white;
    background-color: black;
    padding: 0.2rem;
    color: #fff;
    margin-left: 5px;
    margin-right: 5px;
}

a.category:visited {
    background-color: black;
    color: white;
    padding: 0.2rem;
    color: #fff;
    margin-left: 5px;
    margin-right: 5px;
}
    </style>