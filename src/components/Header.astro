---
import HeaderLink from "./HeaderLink.astro";
import { Desnor } from "@geensnor/astro-componenten";
---

<header class="header">
  <nav>
    <div id="logo"><Desnor /></div>

    <div class="internal-links">
      <HeaderLink href="/">home</HeaderLink>
      <HeaderLink href="/categorie">alle berichten</HeaderLink>
      <HeaderLink href="/zoeken">zoeken</HeaderLink>
      <HeaderLink href="/meer">meer</HeaderLink>
    </div>
    <div class="social-links">
      <a href="https://mastodon.xyz/@geensnor" target="_blank">
        <span class="sr-only">Geensnor op Mastodon</span>
        <svg aria-hidden="true" height="32" viewBox="0 0 16 16" width="32">
          <path
            d="M11.19 12.195c2.016-.24 3.77-1.475 3.99-2.603.348-1.778.32-4.339.32-4.339 0-3.47-2.286-4.488-2.286-4.488C12.062.238 10.083.017 8.027 0h-.05C5.92.017 3.942.238 2.79.765c0 0-2.285 1.017-2.285 4.488l-.002.662c-.004.64-.007 1.35.011 2.091.083 3.394.626 6.74 3.78 7.57 1.454.383 2.703.463 3.709.408 1.823-.1 2.847-.647 2.847-.647l-.06-1.317s-1.303.41-2.767.36c-1.45-.05-2.98-.156-3.215-1.928a3.614 3.614 0 0 1-.033-.496s1.424.346 3.228.428c1.103.05 2.137-.064 3.188-.189zm1.613-2.47H11.13v-4.08c0-.859-.364-1.295-1.091-1.295-.804 0-1.207.517-1.207 1.541v2.233H7.168V5.89c0-1.024-.403-1.541-1.207-1.541-.727 0-1.091.436-1.091 1.296v4.079H3.197V5.522c0-.859.22-1.541.66-2.046.456-.505 1.052-.764 1.793-.764.856 0 1.504.328 1.933.983L8 4.39l.417-.695c.429-.655 1.077-.983 1.934-.983.74 0 1.336.259 1.791.764.442.505.661 1.187.661 2.046v4.203z"
            fill="currentColor"></path>
        </svg>
      </a>
      <a href="https://github.com/geensnor/geensnor.nl" target="_blank">
        <span class="sr-only">Geensnor op GitHub</span>
        <svg aria-hidden="true" height="32" viewBox="0 0 16 16" width="32">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
            fill="currentColor"></path>
        </svg>
      </a>
      <a href="../rss.xml" target="_blank">
        <span class="sr-only">RSS</span>
        <svg
          height="32"
          viewBox="0 0 20 20"
          width="32"
          xmlns="http://www.w3.org/2000/svg"
          ><path
            d="M6.002 15.999a2 2 0 1 0-.004 4a2 2 0 0 0 .004-4M6 4a2 2 0 0 0 0 4c5.514 0 10 4.486 10 10a2 2 0 0 0 4 0c0-7.72-6.28-14-14-14m0 6a2 2 0 0 0 0 4c2.205 0 4 1.794 4 4a2 2 0 0 0 4 0c0-4.411-3.589-8-8-8"
            fill="currentColor"></path></svg
        >
      </a>
    </div>
  </nav>
</header>

<style>
  .header {
    background-image: url("../assets/cropped-Vintage-823x400.jpg");
    background-size: cover;
    background-position: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    position: relative;
    height: 240px;
  }

  .header::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.3);
  }

  nav {
    margin-top: 240px;
    height: 30px;
    z-index: 1;
    width: 100%;
    min-height: 4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--geensnor-oranje-100);
  }

  nav a {
    color: white;
    font-size: var(--geensnor-font-size-l);
  }

  nav a:hover {
    text-decoration: underline;
  }

  #logo {
    width: 120px;
    height: 120px;
    padding-left: 10px;
    padding-right: 90px;
    display: flex;
    filter: invert(1);
  }

  .internal-links {
    display: flex;
    gap: 1.8rem;
  }

  .social-links {
    display: flex;
    justify-content: flex-end;
    width: 220px;
  }

  .social-links a {
    color: white;
    padding: 1em 0.5em;
  }

  @media (max-width: 720px) {
    .social-links {
      display: none;
    }
    #logo {
      display: none;
    }
    nav {
      justify-content: center;
    }
  }
</style>
