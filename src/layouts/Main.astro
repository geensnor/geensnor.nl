---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { Voettekst } from "@geensnor/astro-componenten";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import "@fontsource-variable/work-sans";
import "@fontsource/zilla-slab/500.css";
---

<!doctype html>
<html lang="nl">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      main {
        width: 960px;
        margin-top: 4em;
      }

      @media (max-width: 720px) {
        ul {
          gap: 0.5em;
        }
        ul li {
          width: 100%;
          text-align: center;
        }
        ul li:first-child {
          margin-bottom: 0;
        }
        ul li:first-child .title {
          font-size: 1.563em;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <Header />
      <main>
        <slot />
      </main>
      <Voettekst githubURL="https://github.com/geensnor/" />
    </div>
  </body>
</html>
