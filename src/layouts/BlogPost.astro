---
import { render } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";
import Categorien from "../components/CategorieMeta.astro";
import { Kop } from "@geensnor/astro-componenten";

const { post } = Astro.props;
const { Content } = await render(post);
---

<article>
  <div class="prose">
    <div class="title">
      <Kop Type={"h1"}>
        <a href={'/' + post.id}>{post.data.title}</a>
      </Kop>
      <div class="post-meta">
        {post.data.author} op <FormattedDate date={post.data.date} />
        in <Categorien
          categories={post.rendered.metadata.frontmatter.categories}
        />
      </div>
      <div class="date"></div>
    </div>
    <Content />
  </div>
</article>

<style>
  .post-meta {
    margin-bottom: 4em;
    font-family: var(--geensnor-font-family);
    color: var(--geensnor-grijs-100);
    margin-top: 1em;
    margin-bottom: 4em;
  }

  article {
    margin-top: 60px;
    margin-bottom: 160px;
  }

  @media (max-width: 720px) {
    .post-meta {
      font-size: var(--geensnor-font-size-xxs);
    }
  }
</style>
